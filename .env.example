# =============================================================================
# Open Pickleball — environment variables
# =============================================================================
# The app is LOCAL-FIRST and runs with NO environment variables at all. Data is
# stored on the device (localStorage). There is no backend and nothing to
# configure — this file only documents the one optional, cosmetic variable.
# -----------------------------------------------------------------------------

# Public name shown in the UI / installable app manifest.
NEXT_PUBLIC_APP_NAME="Open Pickleball"
