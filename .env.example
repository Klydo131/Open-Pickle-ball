# =============================================================================
# Open Pickleball — environment variables
# =============================================================================
# The app is LOCAL-FIRST and runs with NO environment variables at all. Copy
# this file to `.env.local` only if you want to enable the OPTIONAL cross-device
# sync layer. `.env.local` is git-ignored — never commit real values.
#
#   cp .env.example .env.local
# -----------------------------------------------------------------------------

# Public name shown in the UI / installable app manifest.
NEXT_PUBLIC_APP_NAME="Open Pickleball"

# ----- Optional cross-device sync (see SYNC.md) ------------------------------
# Sync turns on only when BOTH of these are set. They are PUBLIC values, safe to
# expose to the browser, and protected by locked-down database functions.
# Point them at any hosted Postgres + realtime provider (reference: Supabase).
#
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-publishable-or-anon-key"
#
# SECRET admin/service key — NEVER used by the client, NEVER prefix with
# NEXT_PUBLIC_, and NEVER commit it. Only for server-side/admin tooling.
# SUPABASE_SERVICE_ROLE_KEY=""
