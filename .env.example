# =============================================================================
# Open Pickleball — environment variables
# =============================================================================
# v1 is LOCAL-FIRST: the app runs with NO environment variables at all. Data is
# stored in the browser (localStorage). Copy this file to `.env.local` only when
# you wire up the optional backend described in ARCHITECTURE.md.
#
#   cp .env.example .env.local
# -----------------------------------------------------------------------------

# Public name shown in the UI / PWA manifest.
NEXT_PUBLIC_APP_NAME="Open Pickleball"

# ----- Optional backend (Supabase / Postgres) --------------------------------
# These are NOT required for the local-first build. They are placeholders that
# the documented `RemoteStore` adapter will read once a backend is added.
#
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
#
# SERVER-ONLY secret. NEVER prefix with NEXT_PUBLIC_ and NEVER commit it.
# Used only inside server code / edge functions (see SECURITY.md).
# SUPABASE_SERVICE_ROLE_KEY=""
# DATABASE_URL=""
